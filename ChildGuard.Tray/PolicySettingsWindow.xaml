<Window x:Class="ChildGuard.Tray.PolicySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChildGuard Settings" Height="420" Width="560" WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Quiet Hours">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Start (HH:mm):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="TbQuietStart" Width="100"/>
                        <TextBlock Text="End (HH:mm):" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TextBox x:Name="TbQuietEnd" Width="100"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
                        <Button x:Name="BtnQuietSave" Content="Save" Width="80" Margin="0,0,8,0"/>
                        <Button x:Name="BtnQuietClose" Content="Close" Width="80"/>
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="Tip: Choose Off in Tray -> Policy -> Quiet Hours for disabling quickly. Use this tab to set custom hours." Foreground="#666" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
            <TabItem Header="Enforcement">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Countdown (s):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="TbCountdown" Width="100"/>
                        <TextBlock Text="Warning Cooldown (s):" VerticalAlignment="Center" Margin="16,0,8,0"/>
                        <TextBox x:Name="TbWarnCooldown" Width="120"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
                        <Button x:Name="BtnEnfSave" Content="Save" Width="80"/>
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="Tip: You can also use Tray -> Policy presets for quick changes." Foreground="#666" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
            <TabItem Header="Processes">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Blocked -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Blocked Processes" FontWeight="Bold"/>
                        <ListBox x:Name="LbBlocked" Height="220" Margin="0,6,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TbBlocked" Width="180"/>
                            <Button x:Name="BtnBlockedAdd" Content="Add" Width="60" Margin="6,0,0,0"/>
                            <Button x:Name="BtnBlockedRemove" Content="Remove" Width="70" Margin="6,0,0,0"/>
                            <Button x:Name="BtnBlockedAddActive" Content="Add Active" Width="90" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button x:Name="BtnBlockedImport" Content="Import…" Width="80"/>
                            <Button x:Name="BtnBlockedExport" Content="Export…" Width="80" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Allowed During Quiet Hours -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Allowed During Quiet Hours" FontWeight="Bold"/>
                        <ListBox x:Name="LbAllowedQH" Height="220" Margin="0,6,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TbAllowedQH" Width="180"/>
                            <Button x:Name="BtnAllowedAdd" Content="Add" Width="60" Margin="6,0,0,0"/>
                            <Button x:Name="BtnAllowedRemove" Content="Remove" Width="70" Margin="6,0,0,0"/>
                            <Button x:Name="BtnAllowedAddActive" Content="Add Active" Width="90" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button x:Name="BtnAllowedImport" Content="Import…" Width="80"/>
                            <Button x:Name="BtnAllowedExport" Content="Export…" Width="80" Margin="6,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Running Processes -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Running Processes" FontWeight="Bold"/>
                        <ListBox x:Name="LbRunning" Height="220" Margin="0,6,0,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBlocked}" Value="True">
                                                        <Setter Property="Foreground" Value="Tomato"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAllowed}" Value="True">
                                                        <Setter Property="Foreground" Value="ForestGreen"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnRunRefresh" Content="Refresh" Width="80"/>
                            <Button x:Name="BtnRunAddBlocked" Content="Add to Blocked" Width="110" Margin="6,0,0,0"/>
                            <Button x:Name="BtnRunAddAllowed" Content="Add to Allowed (QH)" Width="150" Margin="6,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="TbRunSearch" Width="160"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <CheckBox x:Name="CbAutoRefresh" Content="Auto Refresh" VerticalAlignment="Center"/>
                            <TextBlock Text="Interval (s):" VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <ComboBox x:Name="CbAutoInterval" Width="80">
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="30"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

